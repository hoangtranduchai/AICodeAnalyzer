# Copy to .env or set these values in your shell/session.
# Never put real secrets in this example file.

DB_URL=jdbc:sqlserver://localhost:1433;databaseName=CodeAnalyzerDb;encrypt=true;trustServerCertificate=true
DB_USERNAME=code_analyzer_app
DB_PASSWORD=change_me_locally

GEMINI_API_KEY=replace_with_local_key_only
APP_CONFIG_FILE=application.properties
